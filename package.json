{
  "name": "barbearia-agendamento",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "tsx --test src/**/*.test.ts",
    "test:integration": "tsx --test src/test/http.integration.test.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "db:generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "db:push:postgres": "prisma db push --schema prisma/postgres/schema.prisma",
    "db:migrate:postgres": "prisma migrate dev --schema prisma/postgres/schema.prisma",
    "db:deploy:postgres": "prisma migrate deploy --schema prisma/postgres/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "prisma": "^5.14.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
